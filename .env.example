CDN_DIR=".cdn"
LISTEN_HOST="0.0.0.0"
LISTEN_PORT="8000"

# Address reachable by WireGuard clients for the realtime multiplayer server.
STARPOINT_MULTI_HOST="10.13.13.1"
STARPOINT_MULTI_PORT="18888"
STARPOINT_DUMMY_MULTI_RESPONSE_MODE="accept_array_params"
STARPOINT_DUMMY_MULTI_SKIP_EARLY_BATTLE_START="1"
STARPOINT_DUMMY_MULTI_ACCEPT_ROOM_NUMBER="1"

